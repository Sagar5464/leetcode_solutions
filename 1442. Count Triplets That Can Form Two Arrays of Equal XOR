int countTriplets(int* arr, int a) {
    int count = 0;
    int num[a + 1];
    num[0] = 0;
    for (int i = 0; i < a; i++) {
        num[i + 1] = num[i] ^ arr[i];
    }
    for (int i = 0; i < a; i++) {
        for (int j = i + 1; j < a; j++) {
            for (int k = j; k < a; k++) {
                int a = num[j] ^ num[i];
                int b = num[k + 1] ^ num[j];
                
                if (a == b) {
                    count++;
                }
            }
        }
    }
    return count;
}
