class Solution {
public:
    vector<int> getFinalState(vector<int>& nums, int k, int m) {
        while(k--){
            int min=nums[0];
            int idx=0;
            for(int i=0;i<nums.size();i++){
                if(nums[i]<min){
                    min=nums[i];
                    idx=i;
                }
            }
            nums[idx]=nums[idx]*m;
        }
        return nums;
    }
};
