class Solution {
public:
    bool canPlaceFlowers(vector<int>& arr, int n) {
        if(n==0) return 1;
         int i=0;
        int cnt=0;
        int p=0; 

        if(arr.size()==1 && arr[0]==1) return 0;
        else if(arr.size()==1 && arr[0]==0) return 1;
        if(arr[0]==0){
            while(arr[i]!=1){
                cnt++;
                i++;
                if(i>=arr.size()) break;
            }
            p=cnt/2;
            if(i>=arr.size() && cnt%2!=0) p++;
            if(p>=n) return 1;
        }
        cout<<p<<"\n";
        int c;
        for(int j=i+1;j<arr.size();j++){
            c=0;
            while(j<arr.size() && arr[j]!=1){
                    c++;
                    j++;
            }
            if(j==arr.size()) p+=c/2;
            else if(c%2==0) p+=(c/2-1);
            else p+=(c/2);
        }
        return (p>=n);
    }
};
