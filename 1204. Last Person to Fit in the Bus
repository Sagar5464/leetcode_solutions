/* Write your PL/SQL query statement below */
WITH abc AS
(
    SELECT PERSON_ID,
    PERSON_NAME,
    WEIGHT,
    TURN,
    SUM(WEIGHT) OVER(ORDER BY TURN) AS SUM_SALARY FROM QUEUE
),
CTE_1 AS
(
    SELECT PERSON_NAME,SUM_SALARY,DENSE_RANK() OVER(ORDER BY SUM_SALARY desc) as RNK FROM abc
    WHERE SUM_SALARY<=1000
)
SELECT person_name FROM CTE_1
WHERE RNK=1;
