class Solution {
public:
    int repeatedNTimes(vector<int>& nums) {
        map<int,int>arr;
        for(auto i:nums){
            arr[i]++;
        }
        for(auto i:arr){
            if(i.second==(nums.size()/2)){
                return i.first;
            }
        }
        return 0;
    }
};
