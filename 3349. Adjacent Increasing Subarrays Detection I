class Solution {
public:
    bool hasIncreasingSubarrays(vector<int>& nums, int k) {
        int n = nums.size();
        for (int i = 0; i + 2*k <= n; i++) {
            int c = 0, s = 0;

            for (int j = i + 1; j < i + k; j++) {
                if (nums[j] > nums[j - 1]) c++;
            }

            for (int x = i + k + 1; x < i + 2*k; x++) {
                if (nums[x] > nums[x - 1]) s++;
            }

            if (c == k - 1 && s == k - 1) return true; 
        }
        return false;
    }
};
