int countSymmetricIntegers(int l, int h) {
   int res = 0;
    for (int a = l; a <= h; ++a) {
        if (a < 100 && a % 11 == 0) {
            res++;
        } else if (1000 <= a && a < 10000) {
            int left = a / 1000 + (a % 1000) / 100;
            int right = (a % 100) / 10 + a % 10;
            if (left == right) {
                res++;
            }
        }
    }
    return res;
}
