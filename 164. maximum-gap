void merge(int *arr,int left, int mid, int right){
    int i=left;
    int j=mid+1;
    int ar[right-left+1];
    int k=0;
    while(i<=mid && j<=right){
        if(arr[i]<arr[j]){
            ar[k++]=arr[i++];
        }
        else{
            ar[k++]=arr[j++];
        }
    }
   
    while(i<=mid){
        ar[k++]=arr[i++];
    }
   
    while(j<=right){
        ar[k++]=arr[j++];
    }
   
    k=0;
    for(int i=left;i<=right;i++){
        arr[i]=ar[k];
        k++;
    }
}
void mergesort(int *arr,int n,int left,int right){
    if(left>=right) return;
    if(left<right){
        int mid=(left+right)/2; 
        mergesort(arr,n,left,mid);
        mergesort(arr,n,mid+1,right);
        merge(arr,left,mid,right);
         
    }
}
int maximumGap(int* nums, int n) {
    if(n==1)return 0;
    mergesort(nums,n,0,n-1);
    int c=INT_MIN;
    for(int i=1;i<n;i++){
        if(c<=(nums[i]-nums[i-1])){
            c=nums[i]-nums[i-1];
        }
    }
    return c;

}
