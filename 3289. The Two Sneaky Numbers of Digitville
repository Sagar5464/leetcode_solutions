class Solution {
public:
    vector<int> getSneakyNumbers(vector<int>& nums) {
        map<int,int> mpp;
        vector<int> arr;
        for(int i : nums){
            mpp[i]++;
        }
        for(auto i : mpp){
            if(i.second>1) arr.push_back(i.first);
        }
        return arr;
    }
};
