bool isPalindrome(char* str) {
    int i = 0;
    int j = strlen(str) - 1;
    while (i <= j) {
        if (str[i] != str[j]) 
            return false;
        i++;
        j--;
    }
    return true;
}
char* firstPalindrome(char** words, int wordsSize) {
     for (int i = 0; i < wordsSize; i++) {
        if (isPalindrome(words[i])) {
            return words[i]; 
        }
    }
    return "";  
}
