class Solution {
public:
    int maximumEnergy(vector<int>& energy, int k) {
        int n = energy.size();
        vector<int> arr(k, 0);
        int c = INT_MIN;

        for (int i = n - 1; i >= 0; i--) {
            int j = i % k;
            arr[j] += energy[i];
            c = max(c, arr[j]);
        }

        return c;
    }
};
