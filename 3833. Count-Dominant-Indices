class Solution {
public:
    int avg(vector<int>nums,int j){
        int c=0,s=0;
        for(int i=j+1;i<nums.size();i++){
            c++;
            s+=nums[i];
        }
        return (int)s/c;
    }
    int dominantIndices(vector<int>& nums) {
        int cnt=0;
        for(int i=0;i<nums.size()-1;i++){
            if(nums[i]>avg(nums,i)){
                cnt++;
            }
        }
        return cnt;
    }
};
