int mostWordsFound(char** sentences, int n) {
     int max = 1;

    for (int i = 0; i < n; i++) {
        int c = 1;
        for (int j = 0; sentences[i][j] != '\0'; j++) {
            if (sentences[i][j] == ' ')
                c++;
        }
        max = c > max ? c : max;
    }
    return max;
}
