double findMedianSortedArrays(int* nums1, int a, int* nums2, int b) {
    int m = a + b;
    int arr[m];
    int i = 0, j = 0, k = 0;

    while (i < a && j < b) {
        if (nums1[i] < nums2[j]) {
            arr[k++] = nums1[i++];
        } else {
            arr[k++] = nums2[j++];
        }
    }

    while (i < a) {
        arr[k++] = nums1[i++];
    }
    while (j < b) {
        arr[k++] = nums2[j++];
    }
    if (m % 2 != 0) {
        return (double)arr[m / 2];
    } else {
        int mid1 = arr[m / 2 - 1];
        int mid2 = arr[m / 2];
        return (double)(mid1 + mid2) / 2.0;
    }
}
