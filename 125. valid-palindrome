class Solution {
public:
    bool isPalindrome(string s) {
        string a = "", b = "";
        for(int i=0;i<s.size();i++){
           if ((s[i] >= 'a' && s[i] <= 'z') ||(s[i] >= 'A' && s[i] <= 'Z') ||(s[i] >= '0' && s[i] <= '9')) {  
                a += tolower(s[i]);
                b += tolower(s[i]);
            }
        }
        reverse(b.begin(), b.end());

        if (a == b)return 1;
        else return 0;
    }
};
