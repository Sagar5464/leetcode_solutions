int maximumCandies(int* candies, int c, long long k) {
    long long t = 0;
    int maxPile = 0;
    for (int i = 0; i < c; i++) {
        t += candies[i];
        if (candies[i] > maxPile) {
            maxPile = candies[i];
        }
    }

    if (t < k) {
        return 0; 
    }

    int l = 1;             
    int h = maxPile;     
    int a = 0;

    while (l <= h) {
        int m = l + (h - l) / 2;
        long long n = 0;
        for (int i = 0; i < c; i++) {
            n += candies[i] / m;
        }

        if (n >= k) {
            a = m;    
            l = m + 1;
        } else {
            h = m - 1;
        }
    }

    return a;
}
