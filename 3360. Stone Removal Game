bool canAliceWin(int n) {
    int a = 0;
    int b = 0;
    int c = 10;
    while (n != 0) {
        if (n >= c) {
            a++;
            n -= c;
            c -= 1;
        }
        if (n >= c) {
            b++;
            n -= c;
            c -= 1;
        } 
        else {
            break;
        }
    }
    if (a > b) {
        return 1;
    }
    return 0;
}
