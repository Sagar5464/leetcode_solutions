class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
        unordered_map<int,int>arr;
        vector<int>ans;
        for(auto i:nums){
            arr[i]++;
        }
        for(auto i:arr){
            if(i.second>(nums.size())/3){
                ans.push_back(i.first);
            }
        }
        return ans;
    }
};
