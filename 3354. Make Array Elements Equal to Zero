class Solution {
public:
    int countValidSelections(vector<int>& nums) {
        int n = nums.size();
        if(n == 1) return 2;
        int l = 0, r = 0;
        for(int i=0;i<n;++i){
            r += nums[i];
        }
        int c = 0;
        for(int i=0;i<n;++i){
            if(nums[i] == 0){
                if(l == r-l){
                    c += 2;
                }
                if(l+1 == r-l || l == r-l+1){
                    c++;
                }
            }
            else{
                l += nums[i];
            }
        }
        return c;
    }
};
