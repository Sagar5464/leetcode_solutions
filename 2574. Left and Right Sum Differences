/**
 * Note: The returned array must be malloced, assume caller calls free().
 */
int* leftRightDifference(int* nums, int n, int* re) {
    int s=0,l=0,r=0;
    int *arr=(int *)malloc(n*sizeof(int));
    for(int i=0;i<n;i++){
        s+=nums[i];
    }
    for(int j=0;j<n;j++){
        r=s-nums[j]-l;
        arr[j]=abs(l-r);
        l+=nums[j];
    }
    *re=n;
    return arr;
}
