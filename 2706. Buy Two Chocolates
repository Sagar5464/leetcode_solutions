int buyChoco(int* prices, int pricesSize, int money) {
    int a;
    for(int i=0;i<pricesSize;i++){
        for(int j=0;j<pricesSize-i-1;j++){
            if(prices[j]>prices[j+1]){
                int t=prices[j];
                prices[j]=prices[j+1];
                prices[j+1]=t;
            }
        }
    }
     if (money >= prices[0] + prices[1]) {
        return money - (prices[0] + prices[1]);
    } else {
        return money;
    }
}
