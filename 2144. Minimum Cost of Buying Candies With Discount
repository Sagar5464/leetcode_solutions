void merge(int *arr,int left, int mid, int right){

    int i=left;
    int j=mid+1;
    int ar[right-left+1];
    int k=0;
    while(i<=mid && j<=right){
        if(arr[i]<arr[j]){
            ar[k++]=arr[i++];
        }
        else{
            ar[k++]=arr[j++];
        }
    }
        while(i<=mid){
        ar[k++]=arr[i++];
    }
     while(j<=right){
        ar[k++]=arr[j++];
    }
     k=0;
    for(int i=left;i<=right;i++){
        arr[i]=ar[k];
        k++;
    }
}
void mergesort(int *arr,int n,int left,int right){
    if(left>=right) return; 
    if(left<right){
        int mid=(left+right)/2;
        mergesort(arr,n,left,mid);
        mergesort(arr,n,mid+1,right);
        merge(arr,left,mid,right);
         
    }
}
int minimumCost(int* cost, int n) {
    int sum=0,car=0;
    mergesort(cost,n,0,n-1);
    for(int i=0;i<n/2;i++){
        int temp=cost[i];
        cost[i]=cost[n-i-1];
        cost[n-i-1]=temp;
    }
    for(int i=0;i<n;i++){
        sum+=cost[i];
    }
    for(int j=2;j<n;j+=3){
        car+=cost[j];
    }
    return sum-car;
}
