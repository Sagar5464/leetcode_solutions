class Solution {
public:
    bool find(vector<int>& piles, int k,int h)
    {
        int sum=0;
        for(int i=0;i<piles.size();i++)
        {
            sum+=(piles[i]+k-1)/k;
        }
        return sum<=h;
    }
    int minEatingSpeed(vector<int>& piles, int h) {
        int low=1;
        int high=1000000000;
        while(low<high)
        {
            int mid=low+(high-low)/2;
            if(find(piles,mid,h))
            {
               high=mid;
            }
            else 
            {
               low=mid+1;
            }
        }
        return low;
    }
};
