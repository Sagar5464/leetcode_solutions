class Solution {
public:
    vector<int> intersection(vector<int>& nums1, vector<int>& nums2) {
        map<int,int>a;vector<int> ans;
        for(int i:nums1) a[i]=1;
        for(int j: nums2){
            if(a[j] == 1){
                ans.push_back(j);
                a[j]++;
            }
        }
        return ans;
    }
};
