class Solution {
public:
    string convertToBase7(int num) {
        if(num==0)return "0";
        string s="";
        int n1=num;
        if(num>0){
        while(num!=0){
            s+=to_string(num%7);
            num/=7;
        }}
        else{
            int n2=num*-1;
            while(n2!=0){
            s+=to_string(n2%7);
            n2/=7;
        }
        }
        reverse(s.begin(),s.end());
        if(n1>0){
        return s;}
        else return '-'+s;
    }
};
