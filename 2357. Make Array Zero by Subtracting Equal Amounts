class Solution {
public:
    int minimumOperations(vector<int>& nums) {
        sort (nums.begin(), nums.end());         
        int n = nums.size();
        int i = 0, j = 0;
        int c = 0, zeros = 0;
        while (i < n) {                
            if (nums[i] == 0)
                zeros++;
            i++;
        }
        while (j < n-1) {                  
            if (nums[j] == nums[j+1] && nums[j]!=0)      
                c++;
            j++;
        }
        return n - zeros - c; 
    }
};
