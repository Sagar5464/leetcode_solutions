class Solution {
public:
    int maxBalancedSubarray(vector<int>& nums) {
        unordered_map<long long,int>mpp;
        int a=0,b=0,c=0;
        long long maxi=2000000000LL;
        mpp[0]=-1;
        for(int i=0;i<nums.size();i++){
            a^=nums[i];
            if(nums[i]%2==0)
                b++;
            else b--;

            long long x=a*maxi+b;

            if(mpp.count(x)){
                c=max(c,i-mpp[x]);
            }
            else mpp[x]=i;
        }
        return c;
    }
};
