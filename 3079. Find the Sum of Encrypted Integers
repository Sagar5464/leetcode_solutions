class Solution {
public:
    int larger_digit(int n) {
        int maxi = 0;
        if (n == 0) return 0;
        while (n) {
            int digi = n % 10;
            maxi = std::max(digi, maxi);
            n /= 10;
        }
        return maxi;
    }

    int sizeofnumber(int n) {
        if (n == 0) return 1;
        int count = 0;
        while (n) {
            count++;
            n /= 10;
        }
        return count;
    }

    int encryptedInt(int count, int maxi) {
        int num = 0;
        for (int i = 0; i < count; i++) {
            num = num * 10 + maxi;
        }
        return num;
    }

    int sumOfEncryptedInt(vector<int>& nums) {
        int sum = 0;
        for (int num : nums) {
            int max_digit = larger_digit(num);
            int num_size = sizeofnumber(num);
            sum += encryptedInt(num_size, max_digit);
        }
        return sum;
    }
};
