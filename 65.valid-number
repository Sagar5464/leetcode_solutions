class Solution {
public:
    bool isNumber(string s) {
        int n = s.size();
        bool dot = 0, d = 0, x = 0;
        for (int i = 0; i < n; i++) {
            if (isdigit(s[i])) {
                d = 1;
            }
            else if (s[i] == '+' || s[i] == '-') {
                if (i > 0 && s[i - 1] != 'e' && s[i - 1] != 'E')
                    return 0;
            }
            else if (s[i] == 'e' || s[i] == 'E') {
                if (x || !d)
                    return 0;
                x = 1;
                d = 0;  
            }
            else if (s[i] == '.') {
                if (dot || x)
                    return 0;
                dot = 1;
            }
            else {
                return 0;
            }
        }
        return d;
    }
};
