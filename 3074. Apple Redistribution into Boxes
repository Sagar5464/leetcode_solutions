int minimumBoxes(int* apple, int appleSize, int* capacity, int capacitySize) {
    int n=capacitySize,s=0,c=0;
    for(int i=0;i<n;i++){
        for(int j=0;j<n-i-1;j++){
            if(capacity[j]>capacity[j+1]){
                int t=capacity[j];
                capacity[j]=capacity[j+1];
                capacity[j+1]=t;
            }
        }
    }
    for(int i=0;i<appleSize;i++){
        s+=apple[i];
    }
    for(int i=n-1;i>=0;i--){
        if(s>0){
            s-=capacity[i];
            c++;
        }
    }
    return c;
}
