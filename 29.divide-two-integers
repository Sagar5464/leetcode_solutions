int divide(int dividend, int divisor) {
    if (divisor == 0) {
        return 0; 
    }

    long long quotient = (long long)dividend / divisor;

    if (quotient > 2147483647) { 
        return 2147483647;
    } else if (quotient < -2147483648) { 
        return -2147483648;
    } else {
        return (int)quotient; 
    }
}
