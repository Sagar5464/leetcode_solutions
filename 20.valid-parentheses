class Solution {
public:
    bool isValid(string s) {
        int n=s.size();
        int top=-1;
        if(n%2!=0)return 0;
        vector<char>arr(n);
        for(int i=0;i<n;i++){
            if(s[i]=='(' || s[i]=='[' ||s[i]=='{' ){
                top++;
                arr[top]=s[i];
            }
            else if(top==-1){
                return 0;
                top++;
            }
            else if(arr[top]=='(' && s[i]==')'){
                top--;
            }
            else if(arr[top]=='{' && s[i]=='}'){
                top--;
            }
            else if(arr[top]=='[' && s[i]==']'){
                top--;
            }
            else {
                return false;
            }
        }
        if(top==-1)return 1;
        else return 0;
    }
};
