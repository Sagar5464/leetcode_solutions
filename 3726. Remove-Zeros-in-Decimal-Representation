class Solution {
public:
    long long removeZeros(long long n) {
        long long a=0;
        while(n>0){
            int d=n%10;
            if(d!=0){
                a=a*10+d;
            }
            n/=10;
        }
        long long s=0;
        while(a>0){
            s=s*10+a%10;
            a/=10;
        }
        return s;
    }
};
