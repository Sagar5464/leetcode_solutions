int countPrimes(int n) {
        int primes[n + 1];
        int c = 0;
        for (int i = 2; i <= n; i++){
            primes[i] = 1;
        }
        for (int i = 2; i <= sqrt(n); i++){
            if (primes[i] == 1) {
                for (int j = i * i; j <= n; j = j + i) {
                    primes[j] = 0;
                }
            }
        }
        for (int i = 2; i < n; i++)  {
            if (primes[i] == 1)
                c++;
        }
        return c;
}
