class Solution {
public:
    long long sumAndMultiply(int n) {
        string s=to_string(n);
        string x="";
        long long sum=0;
       for(auto i:s){
           if(i!='0'){
               x+=i;
           }
       }
        if(x.empty())return 0;
        long long a=stoll(x);
        long long temp=a;
        while(temp>0){
            sum+=temp%10;
            temp/=10;
        }
        return a*sum;
    }
};
