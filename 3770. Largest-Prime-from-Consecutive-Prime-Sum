
class Solution {
public:
    int largestPrime(int n) {
        if (n < 2) return 0;
        int latrevison=n;
        vector<bool> isPrime(latrevison+1,true);
        isPrime[0]=false;
        isPrime[1]=false;
        for(int i=2;i*i<=latrevison;i++){
            if(isPrime[i]){
                for(int j=i*i;j<=latrevison;j+=i){
                    isPrime[j]=false;
                }
            }
        }
        vector<int> primes;
        for(int i=2;i<=latrevison;i++){
            if(isPrime[i]){
                primes.push_back(i);
            }
        }
        vector<long long> prefix(primes.size());
        prefix[0]=primes[0];
        for(int i=1;i<primes.size();i++){
            prefix[i]=prefix[i-1]+primes[i];
        }
        int ans=0;
        for(int i=0;i<prefix.size();i++)
        {
            long long sum=prefix[i];
            if(sum>latrevison)
                break;
            if(isPrime[sum]){
                ans=max(ans, (int)sum);
            }
        }    return ans;
    }
};
