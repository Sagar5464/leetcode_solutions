void merge(int *arr,int left, int mid, int right){
    int i=left;
    int j=mid+1;
    int ar[right-left+1];
    int k=0;
    while(i<=mid && j<=right){
        if(arr[i]<arr[j]){
            ar[k++]=arr[i++];
        }
        else{
            ar[k++]=arr[j++];
        }
    }
   
    while(i<=mid){
        ar[k++]=arr[i++];
    }
   
    while(j<=right){
        ar[k++]=arr[j++];
    }
   
    k=0;
    for(int i=left;i<=right;i++){
        arr[i]=ar[k];
        k++;
    }
}
void mergesort(int *arr,int n,int left,int right){
    if(left>=right) return;
    if(left<right){
        int mid=(left+right)/2; 
        mergesort(arr,n,left,mid);
        mergesort(arr,n,mid+1,right);
        merge(arr,left,mid,right);
         
    }
}
int minMovesToSeat(int* s1, int n1, int* s2, int n2) {
    int s=0;
    mergesort(s1,n1,0,n1-1);
    mergesort(s2,n2,0,n2-1);
    n1=n2;
    for(int i=0;i<n1;i++){
        s+=abs(s1[i]-s2[i]);
    }
    return s;
}
