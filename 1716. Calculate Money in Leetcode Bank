class Solution {
public:
    int totalMoney(int n) {
    int total = 0;
    int week = 0;
    int day = 0;
    int currentMoney = 1;

    for (int i = 1; i <= n; ++i) {
        total += currentMoney;
        day++;

        if (day == 7) {
            week++;
            day = 0;
            currentMoney = week + 1;
        } else {
            currentMoney++;
        }
    }
    return total;
    }
};
