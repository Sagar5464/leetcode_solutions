bool digitCount(char* num) {
     int len = strlen(num);
    
    for(int i = 0; i < len; ++i) {
        int f = 0;
        for(int j = 0; j < len; ++j) {
            if(num[j] == '0' + i) {
                f++;
            }
        }
        if(num[i] - '0' != f) { 
            return 0; 
        }
    }
    return 1; 
}
