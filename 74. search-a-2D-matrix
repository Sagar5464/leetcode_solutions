class Solution {
public:
    bool searchMatrix(vector<vector<int>>& m, int target) {
        bool c=0;
        for(int i=0;i<m.size();i++){
            for(int j=0;j<m[i].size();j++){
                if(m[i][j]==target){
                    c=1;
                }
            }
        }
        return c;
    }
};
