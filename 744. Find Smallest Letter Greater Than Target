class Solution {
public:
    char nextGreatestLetter(vector<char>& letters, char target) {
        int low=0, high=letters.size() -1;
        int mid;
        int i=-1;
        while(low<=high)
        {
            mid = (low+high)/2;
            if(letters[mid]>target)
            {
                i=mid;
                high = mid-1;
            }
            else
            {
                low=mid+1;
            }
        }
        if(i==-1)return letters[0];
        else return letters[i];
    }
};
