class Solution {
public:
    int numRescueBoats(vector<int>& p, int l) {
        sort(p.begin(),p.end());
        int i=0 , c=0;
        int j=p.size()-1;
        while(i<=j){
            if(p[i]+p[j]<=l){
                i++;
                j--;
                c++;
            }
            else{
                c++;
                j--;
            }
        }
        return c;
    }
};
