int majorityElement(int* nums, int n) {
    int s = 0, c = 0;
        for(int i = 0; i < n; i++ ) {
            if(c == 0){
                s = nums[i];
                c = 1;
            }
            else if(s == nums[i]){
                c++;
            }
            else{
                c--;
            }
        }
        return s;
}
