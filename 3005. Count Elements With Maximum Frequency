class Solution {
public:
    int maxFrequencyElements(vector<int>& nums) {
        map<int,int>mpp;
        for(auto i:nums){
            mpp[i]++;
        }
        int c=0,s=0;
        for(auto i:mpp){
            s=max(s,i.second);
        }
        for(auto i : mpp){
            if(i.second==s){
                c++;
            }
        }
        return s*c;
    }
};
