class Solution {
public:
    int minimumFlips(int n) {
        string a="";
        while(n>0){
            a=char((n%2)+'0')+a;
            n/=2;
        }
        int c=0;
        int i=0,j=a.size()-1;
        while(i<j){
            if(a[i]!=a[j])c+=2;
            i++;
            j--;
        }
        return c;
    }
};
