class Solution {
public:
    int totalWaviness(int a, int b) {
        int c=0;
        for(int i=a;i<=b;i++){
            string s=to_string(i);
            if(s.size()<3)continue;
            for(int j=1;j<s.size()-1;j++){
                int left=s[j-1]-'0';
                int mid=s[j]-'0';
                int right=s[j+1]-'0';
                if(mid>left && mid>right){c++;}
                else if(mid<left && mid <right){c++;}
            }
        }
        return c;
    }
};
