int minElement(int* nums, int numsSize) {
    int x = 0;
    for (int i = 0; i < numsSize; i++) {
        while (nums[i] > 0) {
            x += nums[i] % 10;
            nums[i] /= 10;
        }
        nums[i] = x;
        x = 0;
    }
    x = nums[0];
    for (int i = 1; i < numsSize; i++) {
        if (nums[i] < x)
            x = nums[i];
    }
    return x;
}
