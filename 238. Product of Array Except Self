/**
 * Note: The returned array must be malloced, assume caller calls free().
 */
int* productExceptSelf(int* nums, int n, int* r) {
    int* a = (int*)malloc(n * sizeof(int));
    *r = n;

    a[0] = 1;
    for (int i = 1; i < n; i++) {
        a[i] = a[i - 1] * nums[i - 1];
    }

    int right = 1;
    for (int i = n - 1; i >= 0; i--) {
        a[i] *= right;
        right *= nums[i];
    }

    return a;
}
