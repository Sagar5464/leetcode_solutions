bool areNumbersAscending(char* s) {
     int n = strlen(s);
    int arr[100];
    int c = 0;
    int cu = 0;

    for (int i = 0; i < n; i++) {
        if (s[i] >= '0' && s[i] <= '9') {
            cu = cu * 10 + (s[i] - '0');
        } else if (cu != 0) {
            arr[c++] = cu;
            cu = 0;
        }
    }

    if (cu != 0) {
        arr[c++] = cu;
    }

    for (int i = 0; i < c; i++) {
        printf("%d\n", arr[i]);
    }

    for (int i = 0; i < c - 1; i++) {
        if (arr[i] >= arr[i + 1]) {
            return false;
        }
    }

    return true;
}
