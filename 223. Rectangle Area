int area(int a,int b,int c,int d){
    int l=c-a;
    int br=d-b;
    return l*br;
}
int max(int a,int b){
    return (a>b)?a:b;
}
int min(int a,int b){
    return (a<b)?a:b;
}

int computeArea(int ax1, int ay1, int ax2, int ay2, int bx1, int by1, int bx2, int by2) {
    // if(ax1==bx1 && ay1==by1 && ax2==bx2 && ay2==by2){
    //     return ax1*ax2*ay1*ay2;
    // }
    int left=area(ax1,ay1,ax2,ay2);
    int right=area(bx1,by1,bx2,by2);
    int carea=0;
    int le = max(ax1, bx1);
    int rig = min(ax2, bx2);
    int to = min(ay2, by2);
    int bo = max(ay1, by1);
        
        if(le < rig && to > bo){
            carea = (rig-le) *(to-bo);
        }
    return left+right-carea;
}
