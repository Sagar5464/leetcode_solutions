class Solution {
public:
    int minimumIndex(vector<int>& arr, int c) {
        int x=INT_MAX;
        int s=-1;
        int n=arr.size();
        for(int i=0;i<n;i++){
            if(arr[i]>=c){
                if(arr[i]<x){
                    x=arr[i];
                    s=i;
                }
            }
        }
        return s;
    }
};
