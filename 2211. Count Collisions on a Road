class Solution {
public:
    int countCollisions(string s) {
        int c=0;
        for(int i=0;i<s.size()-1;i++){
            if(s[i]=='R' && s[i+1]=='L'){
                c+=2;
                s[i]='S';
                s[i+1]='S';
            }
            else if(s[i]=='R' && s[i+1]=='S'){
                c+=1;
                s[i]='S';
            }
            else if(s[i]=='S' && s[i+1]=='L'){
                c+=1;
                s[i+1]='S';
            }
            else if(i!=0 && s[i]=='L' && s[i-1]=='S'){
                c+=1;
                s[i]='S';
            }
        }
        for(int i=s.size()-1;i>0;i--){
            if(s[i]=='S' && s[i-1]=='R'){
                c++;
                s[i-1]='S';
            }
        }
        return c;
    }
};
