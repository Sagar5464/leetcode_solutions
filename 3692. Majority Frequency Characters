class Solution {
public:
    string majorityFrequencyGroup(string s) {
        vector<int> freq(26, 0);
        for (const char& ch : s)
            freq[ch - 'a']++;
        int c = 0, sum = 0;
        unordered_map<int, int> arr;
        for (const int& f : freq)
            if (f > 0)
                c = max(c, ++arr[f]);
        for (const auto& [f, cnt] : arr){
            if (cnt == c)
                sum = max(sum, f);}
        string ans = "";
        for (int i = 0; i < 26; i++){
            if (freq[i] == sum && arr[freq[i]] == c)
                ans += (i + 'a');}
        return ans;
    }
};
