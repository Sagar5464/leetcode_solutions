class Solution {
public:
    int largestPerimeter(vector<int>& nums) {
        sort(begin(nums),end(nums));
        int s = 0, a, b, c;
        for(int i=0; i<nums.size()-2; i++)
        {
            a = nums[i],
            b = nums[i+1],
            c = nums[i+2];
            if(a+b>c)
                s = max(a+b+c, s);
        }
        return s;
    }
};
