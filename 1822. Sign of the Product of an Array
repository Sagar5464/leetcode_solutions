int arraySign(int* nums, int n) {
    int x=0,c=0;
    for(int i=0;i<n;i++){
        if(nums[i]<0){
            x++;
        }
        if(nums[i]==0){
            c++;
        }
    }
    if(c==0){
        if(x%2==0){
            return 1;
        }
        else return -1;
    }
    else return 0;
}
