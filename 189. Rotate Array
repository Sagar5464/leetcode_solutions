void rotate(int* nums, int n, int k) {
    if (n <= 1 || k == 0) {
        return;
    }
    k = k % n;
    void reverse(int* arr, int start, int end) {
        while (start < end) {
            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;
            start++;
            end--;
        }
    }
    reverse(nums, 0, n - 1);
    reverse(nums, 0, k - 1);
    reverse(nums, k, n - 1);
}
