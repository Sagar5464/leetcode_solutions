class Solution {
public:
    int longestBalanced(vector<int>& nums) {
        int n = nums.size();
        int a = 0;
        for (int i = 0; i < n; i++) {
            unordered_map<int, int> arr;
            int c = 0, s = 0;
            for (int j = i; j < n; j++) {
                int x = nums[j];
                if (arr[x] == 0) {
                    if (x % 2 == 0) c++;
                    else s++;
                }
                arr[x]++;
                if (c == s) {
                    a = max(a, j - i + 1);
                }
            }
        }
        return a;
    }
};
