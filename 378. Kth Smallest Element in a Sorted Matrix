class Solution {
public:
    int kthSmallest(vector<vector<int>>& m, int k) {
        int n = m.size();
        int low = m[0][0];
        int high = m[n-1][n-1];

        while(low < high) {
            int mid = low + (high - low) / 2;
            int c = 0;
            int j = n - 1;

            for(int i = 0; i < n; i++) {
                while(j >= 0 && m[i][j] > mid) j--;
                c += (j + 1);
            }

            if(c < k) low = mid + 1;
            else high = mid;
        }
        return low;
    }
};
