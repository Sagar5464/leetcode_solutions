int minimumSum(int* nums, int n) {
    long long max=INT_MAX;
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            for(int k=0;k<n;k++){
                if(i<j && j<k){
                    if(nums[i] < nums[j] && nums[k] < nums[j]){
                        long long p=(long long)nums[i]+nums[j]+nums[k];
                            if(max>p){
                            max=p;
                        }
                    }
                }    
            }
        }
       
    }
     if(max==INT_MAX) return -1;
        else return max;

}
