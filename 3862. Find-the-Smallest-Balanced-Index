class Solution {
public:
    int smallestBalancedIndex(vector<int>& nums) {
        int n=nums.size();
        if(n==1)return -1;
        const long long mx=1e14;
        vector<long long>l(n);
        vector<long long>r(n);
        l[0]=nums[0];
        for(int i=1;i<n;i++){
            l[i]=l[i-1]+nums[i];
        }
        r[n-1]=nums[n-1];
        for(int i=n-2;i>=0;i--){
            if(r[i+1]>mx/nums[i]){
                r[i]=mx+1;
            }
            else r[i]=1LL*r[i+1]*nums[i];
        }
        for(int i=0;i<n;i++){
            int s,c;
            if(i==0)s=0;
            else s=l[i-1];

            if(i==n-1) c=1;
            else c=r[i+1];
            if(s==c){
                return i;
            }
        }
        return -1;
    }
};
