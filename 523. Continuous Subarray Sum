bool checkSubarraySum(int* nums, int n, int k) {
    if (n == 1) return false;
    else if (k == 1) return true;
    
    bool *a = calloc(k, sizeof(bool)); 
    int sum = 0;    

    for(int i = 0; i < n; i++){
        if (nums[i] % k == 0){  
            if (i < n-1 && nums[i+1] % k == 0) return true;
            else continue;
        }
        sum += nums[i]; 
        if (sum % k == 0) return true;
        else if (a[sum % k] > 0) return true;
        a[sum % k] = 1;
    }
    free(a);
    return false;
}
