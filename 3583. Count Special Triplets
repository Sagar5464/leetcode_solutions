class Solution {
public:
    int specialTriplets(vector<int>& nums) {
        long long MOD = 1e9 + 7;
        int n = nums.size();

        vector<long long> right(100001, 0), left(100001, 0);

        for (int x : nums) right[x]++;

        long long c = 0;

        for (int j = 0; j < n; j++) {
            int val = nums[j];
            right[val]--;

            int k = 2 * val;
            if (k <= 100000) {
                long long L = left[k];
                long long R = right[k];
                c += ((L * R) % MOD) % MOD;
            }
            left[val]++;
        }
        return c%MOD;
    }
};
