class Solution {
public:
    bool doesAliceWin(string s) {
        int a=0;
        for(int i=0;i<s.size();i++){
            if(s[i]=='a'||s[i]=='e'||s[i]=='i'||s[i]=='o'||s[i]=='u'){
                a++;
                return 1;
            }
        }
        if(a%2==1)return 1;
        if(a==0)return 0;
        return 0;
    }
};
