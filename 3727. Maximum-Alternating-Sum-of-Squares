class Solution {
public:
    long long maxAlternatingSum(vector<int>& nums) {
        for(int i=0;i<nums.size();i++){
            nums[i]=nums[i]*nums[i];
        }
        sort(nums.begin(),nums.end());
        long long a=0;
        for(int i=0;i<nums.size()/2;i++){
            a+=nums[nums.size()-i-1];
            a-=nums[i];
        }
        if(nums.size()%2!=0){
            a+=nums[nums.size()/2];
        }
        return a;
    }
};
