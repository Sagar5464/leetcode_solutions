class Solution {
public:
    vector<int> decompressRLElist(vector<int>& nums) {
        vector<int>arr;
        for(int i=0;i<nums.size();i+=2){
            int f=nums[i];
            int val =nums[i+1];
            while(f--){
                arr.push_back(val);
            }
        }
        return arr;
    }
};
