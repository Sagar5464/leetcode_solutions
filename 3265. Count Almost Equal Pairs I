class Solution {
public:
    bool isEqual(int x, int y) {
        int a = -1, b = -1;
        while (x > 0 || y > 0) {
            if (x % 10 == y % 10) {
                x /= 10; y /= 10;
            } else if (a == -1) {
                a = x % 10;
                b = y % 10;
                x /= 10; y /= 10;
            } else if (a != -2) {
                if (a == y % 10 && b == x % 10) {
                    a = b = -2;
                    x /= 10; y /= 10;
                } else return false;
            } else return false;
        }
        return a < 0;
    }

    int countPairs(vector<int>& nums) {
        int n = nums.size(), c = 0;
        for (int i = 0; i < n; i++)
            for (int j = i + 1; j < n; j++)
                if (isEqual(nums[i], nums[j])) c++;
        return c;
    }
};
