class Solution {
public:
    int splitNum(int num) {
        string s=to_string(num);
        string a=" ",c=" ";
        sort(s.begin(),s.end());
        for(int i=0;i<s.size();i++){
            if(i%2==0){
                a.push_back(s[i]);
            }
            else {
                c.push_back(s[i]);
            }
        }
        int ans=stoi(c)+stoi(a);
        return ans;
    }
};
