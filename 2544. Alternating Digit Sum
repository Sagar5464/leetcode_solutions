int alternateDigitSum(int n) {
    int a,x,n1=n,s=0,c=0;
    int p=log10(n)+1;
    int *arr=(int *)calloc(p,sizeof(int));
    int k=0;
    while(n1!=0){
        x=n1%10;
        arr[k++]=x;
        n1/=10;
    }
    for(int i=0;i<k/2;i++){
        int t=arr[i];
        arr[i]=arr[k-i-1];
        arr[k-i-1]=t;
    }
    for(int j=0;j<k;j++){
        if(j%2==0){
            s+=arr[j];
        }
        else{
            c+=arr[j];
        }
     
    }
       return s-c;
}
