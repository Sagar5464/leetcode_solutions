class Solution {
public:
    int totalNumbers(vector<int>& d) {
        set<int> combi;
        int n=d.size();
        for(int i=0;i<n;i++){
            if(d[i]==0)continue;
            for(int j=0;j<n;j++){
                if(i==j)continue;
                for(int k=0;k<n;k++){
                    if(k==i || k==j || d[k]%2!=0)continue;
                    int a=d[i]*100+d[j]*10+d[k];
                    combi.insert(a);               
                }
            }
        }
        return combi.size();
    }
};
