int arithmeticTriplets(int* nums, int n, int d) {
    int c=0;
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            for(int k=j+1;k<n;k++){
                if(nums[j]-nums[i]==d && nums[k]-nums[j]==d){
                    c++;
                }
            }
        }
    }
    return c;
}
