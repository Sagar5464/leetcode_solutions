class Solution {
public:
    bool isprime(long long n){
        if(n<=1)return 0;
        if(n<=3)return 1;
        if(n%2==0 || n%3==0)return 0;
        for(int i=5;i*i<=n;i+=6){
            if(n%i==0 || n%(i+2)==0){
                return 0;
            }
        }
        return 1;
    }
    bool completePrime(int num) {
        string s=to_string(num);
        for(int i=1;i<=s.size();i++){
            long long c=stoll(s.substr(0,i));
            if(!isprime(c)){
                return 0;
            }
        }
        for(int i=0;i<s.size();i++){
            long long x=stoll(s.substr(i));
            if(!isprime(x)){
                return 0;
            }
        }
        return 1;
    }
};
