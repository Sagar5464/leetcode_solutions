class Solution {
public:
    int maxEqualFreq(vector<int>& nums) {
        map<int,int> arr, mpp;
        int ans = 0, m = 0;
        for (int i = 0; i < nums.size(); i++) {
            int num = nums[i];
            if (arr[num] > 0) {mpp[arr[num]]--;}
            arr[num]++;
            mpp[arr[num]]++;
            m = max(m, arr[num]);
            int total = i + 1;
            if (m == 1) ans = total;
            else if (mpp[m] * m + 1 == total) ans = total;
            else if (mpp[m - 1] * (m - 1) + m == total) ans = total;
        }
        return ans;
    }
};
