class Solution {
public:
int binarySearch(vector<int>& nums, int t, bool a) {
        int l = 0;
        int r = nums.size() - 1;
        int idx = -1;
        
        while (l <= r) {
            int mid = l + (r - l) / 2;
            
            if (nums[mid] > t) {
                r = mid - 1;
            } else if (nums[mid] < t) {
                l = mid + 1;
            } else {
                idx = mid;
                if (a) {
                    r = mid - 1;
                } else {
                    l = mid + 1;
                }
            }
        }
        
        return idx;
    }
    vector<int> searchRange(vector<int>& nums, int t) {
       vector<int> result = {-1, -1};
        int l = binarySearch(nums, t, true);
        int r = binarySearch(nums, t, false);
        result[0] = l;
        result[1] = r;
        return result;  
    }
};
