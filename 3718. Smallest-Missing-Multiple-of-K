class Solution {
public:
    int missingMultiple(vector<int>& nums, int k) {
        int a=k;
        sort(nums.begin(),nums.end());
        for(int i=0;i<nums.size();i++){
            if(nums[i]==a){
                a+=k;
            }
        }
        if(a==k)return k;
        else return a;
    }
};
