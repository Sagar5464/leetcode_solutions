bool containsZero(int num) {
    if (num == 0) return true;
    while (num > 0) {
        if (num % 10 == 0) return true;
        num /= 10;
    }
    return false;
}

int* getNoZeroIntegers(int n, int* returnSize) {
    int *arr = (int *)malloc(2 * sizeof(int));
    for (int i = 1; i < n; i++) {
        int j = n - i;
        if (!containsZero(i) && !containsZero(j)) {
            arr[0] = i;
            arr[1] = j;
            *returnSize = 2;
            return arr;
        }
    }
    free(arr);
    *returnSize = 0;
    return NULL;
}
