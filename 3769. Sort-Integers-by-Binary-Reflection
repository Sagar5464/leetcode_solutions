class Solution {
public:
    int ref(int n) {
        int c = 0;
        while (n > 0) {
            c = (c << 1) | (n & 1);
            n >>= 1;              
        }
        return c;
    }
    vector<int> sortByReflection(vector<int>& nums) {
        sort(nums.begin(), nums.end(), [&](int a,int b) {
            int ra = ref(a);
            int rb = ref(b);
            if (ra == rb) return a < b; 
            return ra < rb;
        });
        return nums;;
    }
};
