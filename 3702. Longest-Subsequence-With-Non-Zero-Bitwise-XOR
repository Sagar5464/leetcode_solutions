class Solution {
public:
    int longestSubsequence(vector<int>& nums) {
        int s=0;
        for(int i=0;i<nums.size();i++){
            s^=nums[i];
        }
        if(s!=0)return nums.size();
        for(int i=0;i<nums.size();i++){
            if(nums[i]!=0)return nums.size()-1;
        }
        return 0;
    }
};
