int findMaxConsecutiveOnes(int* nums, int n) {
     int temp = 0;
    int max =0;
    int i;
    for(i=0; i<n; i++){
        if(nums[i] == 1){
            temp = temp + 1;
        }
        else{
            if(temp>max){
                max = temp;
            }
            temp = 0;
        }
    }

    if(temp > max){
        max = temp;
    }
    return max;
}
