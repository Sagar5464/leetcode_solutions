class Solution {
public:
    int convertTime(string cu, string co) {
        int a=0, b=0, n, c=0;
        
        a = (int(cu[0])*10+int(cu[1]))*60+int(cu[3])*10+int(cu[4]);
        b = (int(co[0])*10+int(co[1]))*60+int(co[3])*10+int(co[4]);

        n = b-a;
        while(n!=0)
        {
            if(n>=60)
                n -= 60;
            else if(n>=15)
                n -= 15;
            else if(n>=5)
                n -= 5;
            else
                n -= 1;
            c++;
        }
        return c;
    }
};
