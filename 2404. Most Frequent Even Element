int mostFrequentEven(int* nums, int n) {
    int freq[100001] = {0}; 
    int maxFreq = 0;
    int ans = -1;

    for (int i = 0; i < n; i++) {
        if (nums[i] % 2 == 0) {
            freq[nums[i]]++;
        }
    }

    for (int i = 0; i < 100001; i++) {
        if (freq[i] > maxFreq) {
            maxFreq = freq[i];
            ans = i;
        }
    }

    return ans;
}
