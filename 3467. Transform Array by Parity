/**
 * Note: The returned array must be malloced, assume caller calls free().
 */
void merge(int *arr,int left, int mid, int right){
    int i=left;
    int j=mid+1;
    int ar[right-left+1];
    int k=0;
    while(i<=mid && j<=right){
        if(arr[i]<arr[j]){
            ar[k++]=arr[i++];
        }
        else{
            ar[k++]=arr[j++];
        }
    }
   
    while(i<=mid){
        ar[k++]=arr[i++];
    }
   
    while(j<=right){
        ar[k++]=arr[j++];
    }
   
    k=0;
    for(int i=left;i<=right;i++){
        arr[i]=ar[k];
        k++;
    }
}
void mergesort(int *arr,int n,int left,int right){
    if(left>=right) return;
    if(left<right){
        int mid=(left+right)/2; 
        mergesort(arr,n,left,mid);
        mergesort(arr,n,mid+1,right);
        merge(arr,left,mid,right);
         
    }
}
int* transformArray(int* nums, int n, int* r) {
    int *arr=(int *)malloc(n*sizeof(int));
    for(int i=0;i<n;i++){
        if(nums[i]%2==0){
            nums[i]=0;
        }
        else{
            nums[i]=1;
        }
    }
    mergesort(nums,n,0,n-1);
    for(int i=0;i<n;i++){
        arr[i]=nums[i];
    }
    *r=n;
    return arr;
}
