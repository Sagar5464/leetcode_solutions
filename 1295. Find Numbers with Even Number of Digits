int findNumbers(int* nums, int numsSize) {
    int c = 0;
    for (int i = 0; i < numsSize; i++) {
        int temp = nums[i]; 
        int d = 0;

        while (temp != 0) {
            d++;
            temp /= 10;
        }

        if (d % 2 == 0) {
            c++;
        }
    }
    return c;
}
