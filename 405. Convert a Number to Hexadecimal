class Solution {
public:
    string toHex(int num) {
        if(num == 0) return "0";
        unsigned int n=num;
        string ans;
        string s = "0123456789abcdef";

        while (n) {
            ans += s[n % 16];
            n /= 16;
        }

        reverse(ans.begin(), ans.end());
        return ans;
    }
};
