class Solution {
public:
    int getLeastFrequentDigit(int n) {
        vector<int>arr(10,0);
        while(n){
            int x=n%10;
            arr[x]++;
            n/=10;
        }
        int min=INT_MAX,c=INT_MAX;
        for (int i=0;i<10;i++){
            if (arr[i]!=0){
                if (arr[i]<min){
                    min=arr[i];
                    c=i;
                }
            }
        }
        return c;

    }
};
