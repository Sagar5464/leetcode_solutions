class Solution {
public:
    int superpow(int a,int b){
        a%=1337;
        int c=1;
        for(int i=0;i<b;i++){
            c*=a;
            c%=1337;
        }
           return c;
       }
    int superPow(int a, vector<int>& b) {
        int x,c=1,s;
        for(int i=0;i<b.size();i++){
            x=superpow(a,b[i]);
            x*=c;
            x%=1337;
            s=x;
            x=superpow(x,10);
            c=x;
        }
        return s;
    }
};
