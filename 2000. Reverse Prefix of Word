char* reversePrefix(char* word, char ch) {
     int right = 0, left = 0;

    for (int i = 0; word[i] != '\0'; i++) {
        if (word[i] == ch) {
            right = i;
            break;
        }
    }
    while (left < right) {
        char temp = word[left];
        word[left] = word[right];
        word[right] = temp;

        left++;
        right--;
    }
    return word;
}
