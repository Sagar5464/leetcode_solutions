int maxScore(int* cd, int n, int k) {
        int s = 0;
        for (int i = 0; i < k; i++) {
            s += cd[i];
    }

    int c = s;
    for (int i = 1; i <= k; i++) {
        s -= cd[k - i];
        s += cd[n - i];
        if (s > c) {
            c = s;
        }
    }

    return c;

}
