/**
 * Note: The returned array must be malloced, assume caller calls free().
 */
int* sumZero(int n, int* r) {
    int *arr = malloc(4*n);
    *r = n;
    int i=0, j=n-1;
    while(i<=j){
        arr[i] = n*-1;
        arr[j] = n;
        if(i==j) arr[i]=0;
        n--,i++,j--;
    }
    return arr;
}
