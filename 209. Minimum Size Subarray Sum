class Solution {
public:
    int minSubArrayLen(int t, vector<int>& nums) {
        int i=0,j=0;
        int sum=0;
        int ans=INT_MAX;
        int n=nums.size();
        while(j<n){
           sum+=nums[j];
           while(sum>=t){
                ans=min(ans,j-i+1);
                sum-=nums[i];
                i++;
           }
           j++;
        }
        if(ans==INT_MAX)return 0;
        else return ans;
    }
};
