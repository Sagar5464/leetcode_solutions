class Solution {
public:
    int minMaxDifference(int n) {
        string s = to_string(n);
        string x = s;
        char a = x[0];
        for(int i = 0; i < s.size(); i++) {
            if(x[i] == a) {
                x[i] = '0';
            }
        }
        string y = s;
        for(int i = 0; i < s.size(); i++) {
            if(y[i] < '9') {
                char t = y[i];
                for(int j = 0; j < s.size(); j++) {
                    if(y[j] == t) {
                        y[j] = '9';
                    }
                }
                break;
            }
        }
        int d = stoi(y) - stoi(x);
    
        return d;
    }
};
